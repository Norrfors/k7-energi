// Prisma schema – beskriver dina databastabeller
// Tänk det som en "CREATE TABLE" men deklarativt.
// När du ändrar här och kör "npm run db:migrate" uppdateras databasen automatiskt.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Live-karta över alla Homey-enheter – upsertas varje poll-cykel
// Ger alltid aktuellt namn och zon oavsett om Homey bytt namn sedan loggning
model Device {
  id        String   @id                   // Homey UUID (aldrig ändras)
  name      String                         // Aktuellt enhetsnamn i Homey
  zoneId    String?                        // Homey zon-UUID
  zoneName  String?                        // Direkt zonnamn (t.ex. "Altan norr")
  zonePath  String?                        // Full stig (t.ex. "Hem / BV / Altan norr")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Sparar temperaturavläsningar från Homey
model TemperatureLog {
  id          Int      @id @default(autoincrement())
  deviceId    String
  deviceName  String                       // Snapshot: namn vid loggning
  zone        String?                      // Snapshot: zonnamn vid loggning
  zoneId      String?                      // Homey zon-UUID (stabil referens)
  temperature Float
  createdAt   DateTime @default(now())

  @@index([deviceId, createdAt])
}

// Sparar energiavläsningar från Homey
model EnergyLog {
  id             Int      @id @default(autoincrement())
  deviceId       String
  deviceName     String                   // Snapshot: namn vid loggning
  zone           String?                  // Snapshot: zonnamn vid loggning
  zoneId         String?                  // Homey zon-UUID (stabil referens)
  watts          Float
  meterPower     Float?                   // Ackumulerad förbrukning sedan midnatt (kWh) för Pulse
  meterValue     Float?                   // Total mätarställning (kWh) – beräknad vid kalibrering
  meterImported  Float?                   // meter_power.imported från Homey – kumulativ total import (kWh), exakt absolut mätarställning
  accumulatedCost Float?                  // Ackumulerad kostnad sedan midnatt (kr)
  createdAt      DateTime @default(now())

  @@index([deviceId, createdAt])
}

// Elnätsinställningar – nätavgift och relaterad information
// Används för att beräkna total elkostnad (Tibber-pris + nätavgift)
model EnergySettings {
  id                Int      @id @default(autoincrement())
  gridProvider      String   @default("Sundsvalls Elnät") // Nätleverantör
  gridFeePerKwh     Float    @default(1.20)               // Nätavgift inkl. energiskatt och moms (kr/kWh)
  fuse              Int      @default(20)                 // Säkringsstorlek (Ampere)
  annualConsumption Int      @default(20000)              // Årsförbrukning (kWh) – grund för tariffen
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Sparar elpriser från Tibber (via Homey)
// Loggas enbart när priset ändras (normalt en gång per timme)
model PriceLog {
  id           Int      @id @default(autoincrement())
  deviceId     String
  deviceName   String
  zoneId       String?                    // Homey zon-UUID
  priceTotal   Float?                     // Aktuellt elpris SEK/kWh (inkl. skatt)
  priceLevel   String?                    // Prisnivå: CHEAP, NORMAL, EXPENSIVE, VERY_EXPENSIVE
  priceLowest  Float?                     // Dagens lägsta pris SEK/kWh
  priceHighest Float?                     // Dagens högsta pris SEK/kWh
  createdAt    DateTime @default(now())

  @@index([deviceId, createdAt])
}

// Sparar data från externa API:er
model ExternalData {
  id        Int      @id @default(autoincrement())
  source    String        // t.ex. "elpris", "vader"
  data      Json          // Flexibelt JSON-fält
  fetchedAt DateTime @default(now())

  @@index([source, fetchedAt])
}

// Mätardata för Pulse Krokgatan 7 (energimätare)
// Lagrar förbrukning sedan midnatt och total mätarställning
model MeterReading {
  id                              Int      @id @default(autoincrement())
  deviceId                        String   @default("c2314e97-c95b-40d4-9393-dbc541d586d1") // Pulse Krokgatan 7
  deviceName                      String   @default("Pulse Krokgatan 7")
  consumptionSinceMidnight        Float  // Förbrukning sedan midnatt (kWh)
  consumptionSincePreviousReading Float  @default(0) // Förbrukning sedan föregående avläsning (kWh)
  totalMeterValue                 Float  // Total mätarställning (kWh)
  costSinceMidnight               Float?  // Kostnad sedan midnatt
  createdAt                       DateTime @default(now())

  @@index([deviceId, createdAt])
}

// Mätarkalibrering – referenspunkter för att räkna fram korrekta mätarvärden
// Användare matar in manuell avläsning från elmätaren
model MeterCalibration {
  id                    Int      @id @default(autoincrement())
  deviceId              String   @default("c2314e97-c95b-40d4-9393-dbc541d586d1") // Pulse Krokgatan 7
  calibrationValue      Float    // Mätarställningen vid kalibreringen (kWh)
  calibrationDateTime   DateTime // När denna avläsning gjordes
  createdAt             DateTime @default(now())

  @@index([deviceId, calibrationDateTime])
  @@unique([deviceId, calibrationDateTime]) // En kalibrering per tidpunkt per enhet
}

// Daglig aggregering av hela husets elmätardata (Pulse)
// En rad per dag – ersätter rådata för historisk analys
model DailyMeterAggregate {
  id             Int      @id @default(autoincrement())
  date           DateTime @db.Date              // Kalenderdatum (UTC)
  consumptionKwh Float                          // Förbrukning under dagen (kWh)
  meterStart     Float                          // Mätarställning vid dagens start (kWh)
  meterEnd       Float                          // Mätarställning vid dagens slut (kWh)
  avgWatts       Float                          // Genomsnittlig effekt (W)
  peakWatts      Float                          // Toppeffekt under dagen (W)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

// Daglig aggregering av energidata per enhet
model DailyEnergyAggregate {
  id         Int      @id @default(autoincrement())
  date       DateTime @db.Date
  deviceId   String
  deviceName String
  zone       String?
  totalKwh   Float                              // Uppskattad förbrukning (kWh) via watts × tidsintervall
  avgWatts   Float
  peakWatts  Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, deviceId])
  @@index([date])
}

// Daglig aggregering av temperaturdata per sensor
model DailyTemperatureAggregate {
  id         Int      @id @default(autoincrement())
  date       DateTime @db.Date
  deviceId   String
  deviceName String
  zone       String?
  minTemp    Float
  maxTemp    Float
  avgTemp    Float
  readings   Int                                // Antal avläsningar under dagen
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, deviceId])
  @@index([date])
}

// Backupinställningar
// Lagrar användarens backupkonfiguration
model BackupSettings {
  id                 Int      @id @default(autoincrement())
  backupFolderPath   String   @default("./backups") // Sökväg där backups sparas
  enableAutoBackup   Boolean  @default(false) // Aktiverad automatisk backup
  backupDay          String   @default("Monday") // Dag för automatisk backup (Monday-Sunday)
  backupTime         String   @default("02:00") // Tid för automatisk backup (HH:MM)
  lastBackupAt       DateTime? // Senaste backupen
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Sensorsynlighet – lagrar vilka sensorer som ska visas på Dashboard
// Utökat: capabilitiesToLog sparar vilka data-fält som ska loggas för sensorn
model SensorVisibility {
  id          Int      @id @default(autoincrement())
  deviceId    String   @unique // Unik ID från Homey
  deviceName  String   // Sensornamn
  sensorType  String   // "temperature" eller "energy"
  isVisible   Boolean  @default(true) // Ska sensorn visas på Dashboard?
  zone        String   @default("") // Zon: "INNE", "UTE" eller ""
  capabilitiesToLog Json  @default("[]") // Array av capabilities att logga: ["measure_power", "meter_power", "accumulatedCost"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sensorType, isVisible])
}
