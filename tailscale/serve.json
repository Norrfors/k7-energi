{
  "TCP": {
    "443": {
      "HTTPS": true
    },
    "80": {
      "HTTPS": false
    }
  },
  "Web": {
    "${TS_CERT_DOMAIN}:443": {
      "Handlers": {
        "/": {
          "Proxy": "http://frontend:3000"
        }
      }
    },
    "localhost:80": {
      "Handlers": {
        "/": {
          "Proxy": "http://frontend:3000"
        }
      }
    }
  }
}
